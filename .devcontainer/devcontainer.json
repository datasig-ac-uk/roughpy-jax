// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/cpp
{
    "name": "roughpy-jax",

    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },

    "customizations": {
        "vscode":{
            "extensions": [
                "ms-python.debugpy",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/venv/bin/python",
                "python.languageServer": "Pylance",
                "python.testing.pytestEnabled": true,
                "cmake.configureArgs": [
                    "-DCMAKE_MAKE_PROGRAM=/opt/venv/bin/ninja"
                ]
            }
        }
    },
    "postCreateCommand": "uv pip install --python /opt/venv/bin/python --no-build-isolation -e /workspaces/roughpy-jax && /opt/venv/bin/pre-commit install",
    // mount ssh folder for git access
    "mounts": [
        "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached"
    ],

    // Enable debugging in container
    "capAdd": [
        "SYS_PTRACE"
    ],

    // Run args for CUDA in devcontainer
    // NOTE: This is required for gpu access when running with podman
    "runArgs": [
        "--hooks-dir=/usr/share/containers/oci/hooks.d",
        "--device", "/dev/nvidia0",
        "--device", "/dev/nvidiactl",
        "--device", "/dev/nvidia-modeset",
        "--device", "/dev/nvidia-uvm",
        "--device", "/dev/nvidia-uvm-tools",
        "--env", "NVIDIA_VISIBLE_DEVICES=all",
        "--env", "NVIDIA_DRIVER_CAPABILITIES=all"
    ]
}
